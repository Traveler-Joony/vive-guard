{
  "name": "viveguard",
  "publisher": "traveler-joony",
  "displayName": "VibeGuard",
  "version": "0.1.0",
  "description": "Monitor code complexity in real-time for vibe coding projects",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Traveler-Joony/vive-guard.git"
  },
  "bugs": {
    "url": "https://github.com/Traveler-Joony/vive-guard/issues"
  },
  "homepage": "https://github.com/Traveler-Joony/vive-guard#readme",
  "license": "AGPL-3.0",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibeGuard",
          "title": "VibeGuard",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "vibeGuard": [
        {
          "type": "webview",
          "id": "vibeGuard.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "vibeGuard.refresh",
        "title": "VibeGuard: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "vibeGuard.analyze",
        "title": "VibeGuard: Analyze Project"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vibeGuard.refresh",
          "when": "view == vibeGuard.dashboard",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "VibeGuard",
      "properties": {
        "vibeGuard.maxComplexity": {
          "type": "number",
          "default": 15,
          "description": "Maximum cyclomatic complexity allowed per function before triggering a warning."
        },
        "vibeGuard.maxDuplicationRate": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 1,
          "description": "Maximum code duplication rate (0.0–1.0) before triggering a warning."
        },
        "vibeGuard.minPatternConsistency": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum pattern consistency score (0.0–1.0) expected across the codebase."
        },
        "vibeGuard.maxCouplingIndex": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Maximum coupling index (0.0–1.0) allowed for file dependencies."
        },
        "vibeGuard.language": {
          "type": "string",
          "enum": ["auto", "en", "ko", "ja", "zh-cn", "zh-tw", "de", "fr", "es", "pt", "ru"],
          "default": "auto",
          "description": "Display language for VibeGuard UI."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "mocha",
    "test:unit": "mocha 'test/analyzer/**/*.test.ts'",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "pretest": "npm run build"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
